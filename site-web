<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Morpion</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --border: #1e1e2e;
    --x-color: #ff4d6d;
    --x-glow: #ff4d6d55;
    --o-color: #4cc9f0;
    --o-glow: #4cc9f055;
    --text: #e0e0f0;
    --muted: #4a4a6a;
    --win-line: #f8c400;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Animated background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0;
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, var(--bg) 80%);
    z-index: 0;
    pointer-events: none;
  }

  .container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* Header */
  .header {
    text-align: center;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 10vw, 6rem);
    letter-spacing: 0.15em;
    background: linear-gradient(135deg, var(--x-color), var(--o-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .subtitle {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 0.3rem;
  }

  /* Score board */
  .scores {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .score-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.7rem 1.5rem;
    min-width: 80px;
    position: relative;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    transition: all 0.3s;
  }

  .score-card.active-x { border-color: var(--x-color); box-shadow: 0 0 20px var(--x-glow); }
  .score-card.active-o { border-color: var(--o-color); box-shadow: 0 0 20px var(--o-glow); }

  .score-label {
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .score-symbol {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.1em;
  }

  .score-symbol.x { color: var(--x-color); }
  .score-symbol.o { color: var(--o-color); }

  .score-num {
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .vs {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--muted);
    letter-spacing: 0.15em;
  }

  /* Status bar */
  .status {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    height: 1.2em;
    transition: all 0.3s;
    text-align: center;
  }

  .status.winner-x { color: var(--x-color); text-shadow: 0 0 20px var(--x-color); }
  .status.winner-o { color: var(--o-color); text-shadow: 0 0 20px var(--o-color); }
  .status.draw { color: var(--win-line); }

  /* Game board */
  .board-wrap {
    position: relative;
  }

  .board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    background: var(--border);
    border: 1px solid var(--border);
    padding: 3px;
  }

  .cell {
    width: clamp(90px, 22vw, 130px);
    height: clamp(90px, 22vw, 130px);
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 8vw, 4rem);
    letter-spacing: 0.05em;
    position: relative;
    overflow: hidden;
    transition: background 0.15s;
  }

  .cell::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.0);
    transition: background 0.15s;
  }

  .cell:hover:not(.taken)::before {
    background: rgba(255,255,255,0.04);
  }

  .cell:hover:not(.taken) { cursor: pointer; }
  .cell.taken { cursor: default; }

  /* X mark */
  .cell .mark {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60%;
    height: 60%;
    animation: popIn 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .cell .mark.x-mark {
    color: var(--x-color);
    filter: drop-shadow(0 0 12px var(--x-color));
  }

  .cell .mark.o-mark {
    color: var(--o-color);
    filter: drop-shadow(0 0 12px var(--o-color));
  }

  .cell .mark svg {
    width: 100%;
    height: 100%;
  }

  /* Win cells glow */
  .cell.win-cell {
    animation: winPulse 0.6s ease forwards;
  }

  .cell.win-cell .mark.x-mark {
    filter: drop-shadow(0 0 20px var(--x-color)) drop-shadow(0 0 40px var(--x-color));
  }

  .cell.win-cell .mark.o-mark {
    filter: drop-shadow(0 0 20px var(--o-color)) drop-shadow(0 0 40px var(--o-color));
  }

  /* Hover preview */
  .cell:hover:not(.taken)::after {
    content: attr(data-hover);
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 8vw, 4rem);
    opacity: 0.15;
  }
  .cell.turn-x:hover:not(.taken)::after { color: var(--x-color); }
  .cell.turn-o:hover:not(.taken)::after { color: var(--o-color); }

  /* Buttons */
  .actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    transition: all 0.2s;
  }

  .btn:hover {
    border-color: var(--text);
    color: var(--text);
    background: rgba(255,255,255,0.04);
  }

  .btn.primary {
    border-color: var(--x-color);
    color: var(--x-color);
  }

  .btn.primary:hover {
    background: var(--x-glow);
    box-shadow: 0 0 20px var(--x-glow);
  }

  /* Mode selector */
  .mode-btns {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .mode-label {
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    color: var(--muted);
    text-transform: uppercase;
    margin-right: 0.3rem;
  }

  .mode-btn {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .mode-btn.active {
    border-color: var(--o-color);
    color: var(--o-color);
    background: var(--o-glow);
  }

  .mode-btn:hover:not(.active) {
    border-color: var(--muted);
    color: var(--text);
  }

  /* Animations */
  @keyframes popIn {
    0% { transform: scale(0) rotate(-10deg); opacity: 0; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  @keyframes winPulse {
    0% { background: var(--surface); }
    50% { background: rgba(248,196,0,0.08); }
    100% { background: var(--surface); }
  }

  /* Win line overlay */
  .win-line-svg {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 10;
  }

  .win-stroke {
    stroke: var(--win-line);
    stroke-width: 3;
    fill: none;
    stroke-linecap: round;
    filter: drop-shadow(0 0 6px var(--win-line));
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    animation: drawLine 0.4s ease-out 0.1s forwards;
  }

  @keyframes drawLine {
    to { stroke-dashoffset: 0; }
  }

  /* Confetti particles */
  .particle {
    position: fixed;
    pointer-events: none;
    z-index: 100;
    border-radius: 2px;
    animation: fall linear forwards;
  }

  @keyframes fall {
    0% { opacity: 1; transform: translateY(0) rotate(0deg); }
    100% { opacity: 0; transform: translateY(100vh) rotate(720deg); }
  }
</style>
</head>
<body>

<div class="container">
  <div class="header">
    <h1>MORPION</h1>
    <p class="subtitle">Tic · Tac · Toe</p>
  </div>

  <div class="mode-btns">
    <span class="mode-label">Mode :</span>
    <button class="mode-btn active" id="btn2p" onclick="setMode('2p')">2 Joueurs</button>
    <button class="mode-btn" id="btnAI" onclick="setMode('ai')">vs IA</button>
  </div>

  <div class="scores">
    <div class="score-card active-x" id="cardX">
      <span class="score-label">Joueur</span>
      <span class="score-symbol x">X</span>
      <span class="score-num" id="scoreX">0</span>
    </div>
    <span class="vs">VS</span>
    <div class="score-card" id="cardO">
      <span class="score-label">Joueur</span>
      <span class="score-symbol o">O</span>
      <span class="score-num" id="scoreO">0</span>
    </div>
  </div>

  <div class="status" id="status">Tour de X</div>

  <div class="board-wrap" id="boardWrap">
    <div class="board" id="board"></div>
  </div>

  <div class="actions">
    <button class="btn primary" onclick="resetGame()">Nouvelle Partie</button>
    <button class="btn" onclick="resetScores()">Reset Scores</button>
  </div>
</div>

<script>
const WINS = [
  [0,1,2],[3,4,5],[6,7,8],
  [0,3,6],[1,4,7],[2,5,8],
  [0,4,8],[2,4,6]
];

let board = Array(9).fill(null);
let current = 'X';
let gameOver = false;
let scores = { X: 0, O: 0 };
let mode = '2p'; // '2p' or 'ai'

const statusEl = document.getElementById('status');
const scoreXEl = document.getElementById('scoreX');
const scoreOEl = document.getElementById('scoreO');
const cardX = document.getElementById('cardX');
const cardO = document.getElementById('cardO');
const boardEl = document.getElementById('board');

function setMode(m) {
  mode = m;
  document.getElementById('btn2p').classList.toggle('active', m === '2p');
  document.getElementById('btnAI').classList.toggle('active', m === 'ai');
  const label = m === 'ai' ? 'IA' : 'Joueur';
  cardO.querySelector('.score-label').textContent = label;
  resetGame();
}

function buildBoard() {
  boardEl.innerHTML = '';
  board.forEach((val, i) => {
    const cell = document.createElement('div');
    cell.className = 'cell' + (val ? ' taken' : '') + ' turn-' + current.toLowerCase();
    cell.dataset.i = i;
    cell.dataset.hover = current;

    if (val) {
      const mark = document.createElement('div');
      mark.className = 'mark ' + (val === 'X' ? 'x-mark' : 'o-mark');
      mark.innerHTML = val === 'X' ? svgX() : svgO();
      cell.appendChild(mark);
    } else {
      cell.addEventListener('click', () => handleClick(i));
    }
    boardEl.appendChild(cell);
  });
}

function svgX() {
  return `<svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <line x1="8" y1="8" x2="52" y2="52" stroke="currentColor" stroke-width="6" stroke-linecap="round"/>
    <line x1="52" y1="8" x2="8" y2="52" stroke="currentColor" stroke-width="6" stroke-linecap="round"/>
  </svg>`;
}

function svgO() {
  return `<svg viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
    <circle cx="30" cy="30" r="22" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round"/>
  </svg>`;
}

function handleClick(i) {
  if (gameOver || board[i]) return;
  if (mode === 'ai' && current === 'O') return;
  play(i);
}

function play(i) {
  board[i] = current;
  buildBoard();

  const result = checkWin();
  if (result) {
    endGame(result);
    return;
  }

  if (board.every(Boolean)) {
    endGame('draw');
    return;
  }

  current = current === 'X' ? 'O' : 'X';
  updateTurnUI();

  if (mode === 'ai' && current === 'O' && !gameOver) {
    setTimeout(aiMove, 450);
  }
}

function aiMove() {
  const best = getBestMove();
  if (best !== -1) play(best);
}

function getBestMove() {
  // Try to win
  for (let i = 0; i < 9; i++) {
    if (!board[i]) {
      board[i] = 'O';
      if (checkWin()) { board[i] = null; return i; }
      board[i] = null;
    }
  }
  // Block X
  for (let i = 0; i < 9; i++) {
    if (!board[i]) {
      board[i] = 'X';
      if (checkWin()) { board[i] = null; return i; }
      board[i] = null;
    }
  }
  // Center
  if (!board[4]) return 4;
  // Corner
  const corners = [0,2,6,8].filter(c => !board[c]);
  if (corners.length) return corners[Math.floor(Math.random() * corners.length)];
  // Any
  const free = board.map((v,i) => v ? null : i).filter(v => v !== null);
  return free.length ? free[Math.floor(Math.random() * free.length)] : -1;
}

function checkWin() {
  for (const [a,b,c] of WINS) {
    if (board[a] && board[a] === board[b] && board[a] === board[c]) {
      return { winner: board[a], line: [a,b,c] };
    }
  }
  return null;
}

function endGame(result) {
  gameOver = true;
  const cells = boardEl.querySelectorAll('.cell');

  if (result === 'draw') {
    statusEl.textContent = 'Égalité !';
    statusEl.className = 'status draw';
    return;
  }

  const { winner, line } = result;
  scores[winner]++;
  scoreXEl.textContent = scores.X;
  scoreOEl.textContent = scores.O;

  statusEl.textContent = (winner === 'X' || mode === '2p') ? `${winner} gagne !` : (mode === 'ai' && winner === 'O' ? 'L\'IA gagne !' : `${winner} gagne !`);
  statusEl.className = 'status winner-' + winner.toLowerCase();

  line.forEach(i => cells[i].classList.add('win-cell'));
  drawWinLine(line);
  spawnConfetti(winner === 'X' ? '#ff4d6d' : '#4cc9f0');
}

function drawWinLine(line) {
  const wrap = document.getElementById('boardWrap');
  const cells = boardEl.querySelectorAll('.cell');
  const bRect = boardEl.getBoundingClientRect();
  const wRect = wrap.getBoundingClientRect();

  const getCenter = (i) => {
    const r = cells[i].getBoundingClientRect();
    return {
      x: r.left - wRect.left + r.width / 2,
      y: r.top - wRect.top + r.height / 2
    };
  };

  const a = getCenter(line[0]);
  const b = getCenter(line[2]);

  // extend line slightly
  const dx = b.x - a.x, dy = b.y - a.y;
  const len = Math.sqrt(dx*dx + dy*dy);
  const ext = 20;
  const ux = dx/len, uy = dy/len;

  const svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
  svg.classList.add('win-line-svg');
  const line2 = document.createElementNS('http://www.w3.org/2000/svg','line');
  line2.classList.add('win-stroke');
  line2.setAttribute('x1', a.x - ux*ext);
  line2.setAttribute('y1', a.y - uy*ext);
  line2.setAttribute('x2', b.x + ux*ext);
  line2.setAttribute('y2', b.y + uy*ext);
  svg.appendChild(line2);
  wrap.appendChild(svg);
}

function spawnConfetti(color) {
  const colors = [color, '#f8c400', '#ffffff33'];
  for (let i = 0; i < 40; i++) {
    setTimeout(() => {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.cssText = `
        left: ${Math.random() * 100}vw;
        top: -10px;
        width: ${4 + Math.random() * 6}px;
        height: ${8 + Math.random() * 12}px;
        background: ${colors[Math.floor(Math.random() * colors.length)]};
        animation-duration: ${1.5 + Math.random() * 1.5}s;
        animation-delay: ${Math.random() * 0.3}s;
      `;
      document.body.appendChild(p);
      setTimeout(() => p.remove(), 3000);
    }, i * 30);
  }
}

function updateTurnUI() {
  statusEl.className = 'status';
  const label = (mode === 'ai' && current === 'O') ? 'IA' : current;
  statusEl.textContent = `Tour de ${label}`;

  cardX.classList.toggle('active-x', current === 'X');
  cardX.classList.remove('active-o');
  cardO.classList.toggle('active-o', current === 'O');
  cardO.classList.remove('active-x');

  // update cell hover class
  boardEl.querySelectorAll('.cell:not(.taken)').forEach(c => {
    c.classList.remove('turn-x','turn-o');
    c.classList.add('turn-' + current.toLowerCase());
    c.dataset.hover = current;
  });
}

function resetGame() {
  board = Array(9).fill(null);
  current = 'X';
  gameOver = false;
  statusEl.textContent = 'Tour de X';
  statusEl.className = 'status';
  cardX.classList.add('active-x');
  cardX.classList.remove('active-o');
  cardO.classList.remove('active-o','active-x');
  // remove win line svg
  document.querySelectorAll('.win-line-svg').forEach(e => e.remove());
  buildBoard();
}

function resetScores() {
  scores = { X: 0, O: 0 };
  scoreXEl.textContent = 0;
  scoreOEl.textContent = 0;
  resetGame();
}

// Init
buildBoard();
</script>
</body>
</html>